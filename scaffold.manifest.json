{
  "_comment": "Two sections. `optional`: project-shape-dependent modules, individually selectable at install time (everything NOT listed there is core and always installed; core-only is the non-interactive default). `templates`: the per-template catalog (ADR-007) — version/date/sha256 for EVERY template; maintained by `node scripts/update-catalog.mjs`, enforced by test/catalog.test.mjs, never hand-edited.",
  "optional": [
    {
      "id": "migration",
      "label": "Database migrations",
      "description": "Safe expand-contract DB/data migrations. Choose if the project has a database.",
      "kind": "skill",
      "paths": [
        "skills/migration.md"
      ]
    },
    {
      "id": "api-contract",
      "label": "API contracts",
      "description": "Versioning, backward compatibility, deprecation. Choose if the project exposes an API or public interface.",
      "kind": "rule",
      "paths": [
        "rules/api-contract.md"
      ]
    },
    {
      "id": "observability",
      "label": "Observability",
      "description": "Structured logging, metrics, tracing. Choose for a running service (less relevant for a pure library/CLI).",
      "kind": "rule",
      "paths": [
        "rules/observability.md"
      ]
    },
    {
      "id": "resilience",
      "label": "Resilience",
      "description": "Timeouts, retries, idempotency, graceful degradation. Choose if the project crosses network/process boundaries.",
      "kind": "rule",
      "paths": [
        "rules/resilience.md"
      ]
    },
    {
      "id": "accessibility",
      "label": "Accessibility (a11y)",
      "description": "Semantic HTML, keyboard, contrast, ARIA, WCAG. Choose if the project has a user-facing UI.",
      "kind": "rule",
      "paths": [
        "rules/accessibility.md"
      ]
    },
    {
      "id": "i18n",
      "label": "Internationalization (i18n)",
      "description": "Externalized strings, locale-aware formatting, pluralization, RTL. Choose if the project serves more than one language/locale.",
      "kind": "rule",
      "paths": [
        "rules/i18n.md"
      ]
    },
    {
      "id": "config-secrets",
      "label": "Configuration & secrets",
      "description": "Env-based config, startup validation, .env.example, secret rotation. Choose if the project has runtime configuration or secrets.",
      "kind": "rule",
      "paths": [
        "rules/config-secrets.md"
      ]
    },
    {
      "id": "data-privacy",
      "label": "Data privacy (PII)",
      "description": "Minimization, retention/deletion, encryption, consent, no PII in logs. Choose if the project handles personal or sensitive data.",
      "kind": "rule",
      "paths": [
        "rules/data-privacy.md"
      ]
    },
    {
      "id": "incident",
      "label": "Incident & hotfix",
      "description": "Production incident response: mitigate-first, hotfix, postmortem, rollback. Choose for a deployed service.",
      "kind": "skill",
      "paths": [
        "skills/incident.md"
      ]
    }
  ],
