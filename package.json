    "test": "node --test \"test/**/*.test.mjs\""
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "diff": "^5.2.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/diff": "^5.2.1",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  }
}
