{
  "name": "@achieve/ai-scaffold",
  "version": "2.3.0",
  "description": "Install and manage AI workflow structure (.ai/ and .context/) in any project",
  "type": "module",
  "bin": {
    "ai-scaffold": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "scaffold.manifest.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/jcuadros-achieve/ai-scaffold.git"
  },
  "scripts": {
